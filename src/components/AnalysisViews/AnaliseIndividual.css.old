.analise-individual {
    position: relative;
    display: block;
    padding: 2rem;
    padding-left: 390px;
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
}

.analise-individual.sidebar-hidden {
    padding-left: 2rem;
}

.analise-individual.sidebar-hidden .search-section {
    display: none;
}

.sidebar {
    position: absolute;
    left: 2rem;
    top: 2rem;
    width: 350px;
    z-index: 2;
}

.search-section {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    height: fit-content;
    position: sticky;
    top: 2rem;
}

.sidebar-toggle {
    margin-top: 1rem;
    background: #eef2ff;
    color: #4338ca;
    border: 1px solid #c7d2fe;
    border-radius: 10px;
    padding: 0.5rem 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
}

.sidebar-toggle:hover {
    background: #e0e7ff;
    transform: translateY(-1px);
}

.sidebar-toggle.floating {
    align-self: flex-start;
    margin-bottom: 1rem;
}

.details-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.search-section h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem 0;
    font-size: 1.3rem;
    color: #1f2937;
}

.search-container {
    position: relative;
    margin-bottom: 1.5rem;
}

.search-container svg {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
}

.search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 3rem;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.2s;
}

.search-input:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.alunos-list {
    max-height: none;
    overflow-y: visible;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.aluno-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #f9fafb;
    border: 2px solid transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    position: relative;
}

.aluno-item:hover {
    background: #f3f4f6;
    border-color: #667eea;
    transform: translateX(4px);
}

.aluno-item.selected {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-color: #667eea;
    box-shadow: 0 8px 24px rgba(102, 126, 234, 0.35);
    transform: scale(1.02);
    font-weight: 600;
}

.aluno-item.selected:hover {
    box-shadow: 0 12px 32px rgba(102, 126, 234, 0.45);
    transform: scale(1.04);
}

.aluno-nome {
    font-weight: 500;
    font-size: 0.95rem;
}

.aluno-status {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    font-weight: 600;
    text-transform: uppercase;
}

.aluno-status.ativo {
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
}

.aluno-item.selected .aluno-status.ativo {
    background: rgba(255, 255, 255, 0.3);
    color: white;
}

.aluno-status.transferido,
.aluno-status.remanejamento {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
}

.aluno-item.selected .aluno-status.transferido,
.aluno-item.selected .aluno-status.remanejamento {
    background: rgba(255, 255, 255, 0.3);
    color: white;
}

.no-results {
    text-align: center;
    color: #6b7280;
    padding: 2rem;
}

.aluno-details {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.aluno-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 16px;
    padding: 2rem;
    color: white;
    box-shadow: 0 8px 32px rgba(102, 126, 234, 0.25);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
}

.aluno-info {
    text-align: center;
}

.aluno-info h1 {
    margin: 0 0 0.5rem 0;
    font-size: 2rem;
}

.status-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.2);
}

.aluno-nav {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.aluno-nav.left {
    justify-content: flex-start;
}

.aluno-nav.right {
    justify-content: flex-end;
}

.aluno-nav.bottom {
    justify-content: space-between;
    margin-top: 0.5rem;
    width: 100%;
}

.aluno-nav.bottom .aluno-nav-button {
    background: #eef2ff;
    color: #4338ca;
    border: 2px solid #c7d2fe;
}

.aluno-nav.bottom .aluno-nav-button:hover:not(:disabled) {
    background: #e0e7ff;
}

.aluno-nav-button {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    padding: 0.6rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
}

.aluno-nav-button:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
}

.aluno-nav-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.aluno-stats-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.aluno-stat-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: transform 0.2s;
}

.aluno-stat-card:hover {
    transform: translateY(-2px);
}

.aluno-stat-card.media {
    border-left: 4px solid #10b981;
}

.aluno-stat-card.faltas {
    border-left: 4px solid #f59e0b;
}

.aluno-stat-card.melhor {
    border-left: 4px solid #667eea;
}

.aluno-stat-card.risco {
    border-left: 4px solid #ef4444;
}

.aluno-stat-card svg {
    color: #667eea;
    flex-shrink: 0;
}

.aluno-stat-card.media svg {
    color: #10b981;
}

.aluno-stat-card.faltas svg {
    color: #f59e0b;
}

.aluno-stat-card.melhor svg {
    color: #667eea;
}

.aluno-stat-card.risco svg {
    color: #ef4444;
}

.stat-label {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
}

.stat-value-small {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1f2937;
    margin: 0.25rem 0;
}

.stat-nota {
    font-size: 1.5rem;
    font-weight: 700;
    color: #667eea;
}

.alert-section {
    display: flex;
    align-items: start;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(239, 68, 68, 0.1);
    border-left: 4px solid #ef4444;
    border-radius: 12px;
    color: #991b1b;
}
.alert-section svg {
    flex-shrink: 0;
    margin-top: 0.2rem;
}

.graficos-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem;
}

.grafico-card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.grafico-card.full-width {
    grid-column: 1 / -1;
}

.grafico-card h3 {
    margin: 0 0 1.5rem 0;
    font-size: 1.2rem;
    color: #1f2937;
}

.tabela-detalhada {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: visible;
}

.table-container {
    width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    position: relative;
    display: block;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    scrollbar-gutter: stable;
    border-radius: 12px;
    background: white;
}

.tabela-detalhada h3 {
    margin: 0 0 1.5rem 0;
    font-size: 1.2rem;
    color: #1f2937;
}

.tabela-detalhada table,
.detalhamento-multibimestre-table {
    width: max-content;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 1400px;
    table-layout: fixed;
    border-radius: 12px;
    overflow: visible;
}

.tabela-detalhada thead,
.detalhamento-multibimestre-table thead {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.tabela-detalhada thead th:first-child,
.detalhamento-multibimestre-table thead th:first-child {
    position: sticky;
    left: 0;
    z-index: 6;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    box-shadow: 6px 0 10px rgba(0, 0, 0, 0.08);
    text-align: center;
    min-width: 360px;
    background-clip: padding-box;
}

.detalhamento-multibimestre-table th[rowspan] {
    position: sticky;
    left: 0;
    z-index: 6;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    box-shadow: 6px 0 10px rgba(0, 0, 0, 0.08);
    background-clip: padding-box;
}

.tabela-detalhada th,
.detalhamento-multibimestre-table th {
    padding: 1rem 1.25rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.2px;
    white-space: nowrap;
    position: relative;
    z-index: 1;
}

.detalhamento-multibimestre-table th.bimestre-header {
    padding: 0.5rem 1rem;
    text-align: center;
    border-right: 2px solid rgba(255, 255, 255, 0.2);
}

.detalhamento-multibimestre-table th:last-child {
    border-right: none;
}

.tabela-detalhada td,
.detalhamento-multibimestre-table td {
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
    text-align: center;
    color: #374151;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.tabela-detalhada tbody tr:hover,
.detalhamento-multibimestre-table tbody tr:hover {
    background: #f3f4f6;
}

.tabela-detalhada tbody tr:nth-child(even),
.detalhamento-multibimestre-table tbody tr:nth-child(even) {
    background: #fafafa;
}

.tabela-detalhada .disciplina-nome,
.detalhamento-multibimestre-table .disciplina-nome {
    font-weight: 600;
    color: #1f2937;
    position: sticky;
    left: 0;
    background: white;
    z-index: 5;
    min-width: 360px;
    text-align: center;
    white-space: normal;
    background-clip: padding-box;
}

.tabela-detalhada tbody td:first-child,
.detalhamento-multibimestre-table tbody td:first-child {
    position: sticky;
    left: 0;
    background: white;
    z-index: 4;
    box-shadow: 6px 0 10px rgba(0, 0, 0, 0.06);
    background-clip: padding-box;
}

.tabela-detalhada .nota,
.detalhamento-multibimestre-table .nota {
    font-weight: 700;
    font-size: 1.1rem;
}

.tabela-detalhada .nota.aprovado,
.detalhamento-multibimestre-table .nota.aprovado {
    color: #10b981;
}

.tabela-detalhada .nota.reprovado,
.detalhamento-multibimestre-table .nota.reprovado {
    color: #ef4444;
}

.status-badge-small,
.status-badge-mini {
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
}

.status-badge-mini {
    padding: 0.2rem 0.4rem;
    font-size: 0.7rem;
}

.status-badge-small.aprovado,
.status-badge-mini.aprovado {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
}

.status-badge-small.reprovado,
.status-badge-mini.reprovado {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
}

/* ===== Override: Detalhamento por Disciplina ===== */
.detalhamento-table {
    width: max-content;
    min-width: 1200px;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
    border-radius: 12px;
    overflow: visible;
}

.detalhamento-table thead {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.detalhamento-table th,
.detalhamento-table td {
    padding: 0.85rem 1.1rem;
    text-align: center;
    font-size: 0.9rem;
    white-space: nowrap;
}

.detalhamento-table th {
    font-weight: 600;
}

.detalhamento-table td {
    font-weight: 500;
    color: #374151;
    border-bottom: 1px solid #e5e7eb;
}

.detalhamento-table tbody tr:nth-child(even) {
    background: #fafafa;
}

.detalhamento-table tbody tr:hover {
    background: #f3f4f6;
}

.detalhamento-table .sticky-col {
    position: sticky;
    left: 0;
    z-index: 6;
    background: white;
    min-width: 360px;
    max-width: 360px;
    white-space: normal;
    box-shadow: 6px 0 10px rgba(0, 0, 0, 0.06);
}

.detalhamento-table thead .sticky-col {
    z-index: 7;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.col-disciplina { width: 360px; min-width: 360px; max-width: 360px; }
.col-nota { width: 80px; min-width: 80px; max-width: 80px; }
.col-faltas { width: 90px; min-width: 90px; max-width: 90px; }
.col-aus { width: 120px; min-width: 120px; max-width: 120px; }
.col-status { width: 100px; min-width: 100px; max-width: 100px; }
.col-comp { width: 140px; min-width: 140px; max-width: 140px; }

.tabela-detalhada .acima,
.tabela-detalhada .abaixo,
.detalhamento-multibimestre-table .comparacao.acima,
.detalhamento-multibimestre-table .comparacao.abaixo {
    font-weight: 600;
}

.tabela-detalhada .acima,
.detalhamento-multibimestre-table .comparacao.acima {
    color: #10b981;
}

.tabela-detalhada .abaixo,
.detalhamento-multibimestre-table .comparacao.abaixo {
    color: #ef4444;
}

@media (max-width: 1024px) {
    .analise-individual {
        padding-left: 2rem;
    }

    .sidebar {
        position: static;
        width: 100%;
        margin-bottom: 1.5rem;
    }

    .search-section {
        position: static;
    }

    .graficos-section {
        grid-template-columns: 1fr;
    }
}

.col-disciplina {
    width: 360px;
    min-width: 360px;
    max-width: 360px;
}

.col-nota {
    width: 90px;
    min-width: 90px;
    max-width: 90px;
}

.col-faltas {
    width: 90px;
    min-width: 90px;
    max-width: 90px;
}

.col-aus {
    width: 120px;
    min-width: 120px;
    max-width: 120px;
}

.col-status {
    width: 100px;
    min-width: 100px;
    max-width: 100px;
}

.col-comp {
    width: 140px;
    min-width: 140px;
    max-width: 140px;
}