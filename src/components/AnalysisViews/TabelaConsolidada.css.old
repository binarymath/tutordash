.tabela-consolidada-container {
    padding: 2rem;
    max-width: 1800px;
    margin: 0 auto;
}

.consolidada-header {
    text-align: center;
    margin-bottom: 2.5rem;
}

.consolidada-header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.consolidada-header p {
    color: #6b7280;
    font-size: 1.1rem;
    margin: 0;
}

.controls {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.search-box {
    flex: 1;
    min-width: 300px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    transition: all 0.2s;
}

.search-box:focus-within {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.search-box svg {
    color: #6b7280;
    flex-shrink: 0;
}

.search-box input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    color: #1f2937;
}

.disciplina-select {
    padding: 0.75rem 1.25rem;
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    font-size: 1rem;
    color: #1f2937;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 250px;
}

.disciplina-select:hover {
    border-color: #667eea;
}

.disciplina-select:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.disciplina-section {
    margin-bottom: 3rem;
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.disciplina-titulo {
    margin: 0 0 1.5rem 0;
    font-size: 1.5rem;
    color: #1f2937;
    padding-bottom: 1rem;
    border-bottom: 3px solid #667eea;
}

.table-wrapper {
    overflow-x: auto;
}

.tabela-consolidada {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
}

.tabela-consolidada thead {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.tabela-consolidada th {
    padding: 1rem;
    text-align: left;
    font-weight: 700;
    white-space: nowrap;
}

.aluno-col {
    min-width: 250px;
    position: sticky;
    left: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    z-index: 10;
}

.bim-col {
    text-align: center !important;
    min-width: 100px;
}

.media-col {
    text-align: center !important;
    min-width: 120px;
}

.tend-col {
    text-align: center !important;
    min-width: 100px;
}

.tabela-consolidada tbody tr {
    border-bottom: 1px solid #e5e7eb;
    transition: background-color 0.2s;
}

.tabela-consolidada tbody tr:hover {
    background-color: #f9fafb;
}

.tabela-consolidada td {
    padding: 1rem;
}

.aluno-nome {
    font-weight: 600;
    color: #1f2937;
    position: sticky;
    left: 0;
    background: white;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.tabela-consolidada tbody tr:hover .aluno-nome {
    background-color: #f9fafb;
}

.status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.status-badge.ativo {
    background: #d1fae5;
    color: #065f46;
}

.status-badge.transferido,
.status-badge.remanejamento {
    background: #fef3c7;
    color: #92400e;
}

.nota-cell {
    text-align: center;
    font-weight: 600;
    font-size: 1rem;
}

.nota-cell.aprovado {
    color: #10b981;
}

.nota-cell.reprovado {
    color: #ef4444;
}

.media-cell {
    text-align: center;
    font-weight: 700;
    font-size: 1.1rem;
    background: #f9fafb;
}

.media-cell.aprovado {
    color: #059669;
    background: rgba(16, 185, 129, 0.1);
}

.media-cell.reprovado {
    color: #dc2626;
    background: rgba(239, 68, 68, 0.1);
}

.tend-cell {
    text-align: center;
}

.tend-up {
    color: #10b981;
}

.tend-down {
    color: #ef4444;
}

.tend-stable {
    color: #6b7280;
}

.no-data-message {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 16px;
    margin: 2rem;
}

.no-data-message p {
    font-size: 1.2rem;
    color: #6b7280;
    margin: 0;
}

@media (max-width: 1024px) {
    .consolidada-header h1 {
        font-size: 2rem;
    }

    .controls {
        flex-direction: column;
    }

    .search-box,
    .disciplina-select {
        width: 100%;
    }

    .tabela-consolidada {
        font-size: 0.85rem;
    }

    .tabela-consolidada th,
    .tabela-consolidada td {
        padding: 0.75rem 0.5rem;
    }

    .aluno-col {
        min-width: 200px;
    }

    .bim-col,
    .media-col,
    .tend-col {
        min-width: 80px;
    }
}