.file-upload-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  padding: 2rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(102, 126, 234, 0.25);
}

.upload-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  color: white;
}
/* Tailwind migration: styles moved to utility classes */

.upload-header svg {
  flex-shrink: 0;
}

.upload-header h3 {
  margin: 0 0 0.5rem 0;
  font-size: 1.5rem;
  font-weight: 700;
}

.upload-header p {
  margin: 0;
  opacity: 0.95;
  font-size: 1rem;
}

.bimestres-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.bimestre-upload {
  position: relative;
}

.bimestre-button {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem;
  background: white;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: left;
}

.bimestre-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  border-color: #667eea;
}

.bimestre-button.success {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.1) 100%);
  border-color: #10b981;
}

.bimestre-icon {
  flex-shrink: 0;
  color: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
}

.bimestre-button.success .bimestre-icon {
  color: #10b981;
}

.mini-spinner {
  width: 20px;
  height: 20px;
  border: 3px solid #e5e7eb;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.bimestre-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  flex: 1;
}

.bimestre-label {
  font-weight: 700;
  font-size: 1rem;
  color: #1f2937;
}

.bimestre-loaded {
  font-size: 0.85rem;
  color: #10b981;
  font-weight: 600;
}

.bimestre-hint {
  font-size: 0.85rem;
  color: #6b7280;
}

.upload-summary {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 10px;
  color: white;
  font-weight: 600;
  justify-content: center;
}

.upload-summary svg {
  color: #10b981;
}

@media (max-width: 768px) {
  .bimestres-grid {
    grid-template-columns: 1fr;
  }
}