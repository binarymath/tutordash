.seletor-bimestre {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 12px;
}

.seletor-bimestre svg {
    color: white;
    flex-shrink: 0;
}

.bimestre-buttons {
    display: flex;
    gap: 0.5rem;
}

.bim-btn {
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
    min-width: 50px;
}

.bim-btn:hover:not(.disabled) {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
}

.bim-btn.active {
    background: white;
    color: #667eea;
    border-color: white;
}

.bim-btn.disabled {
    opacity: 0.3;
    cursor: not-allowed;
}